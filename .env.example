# Model 3 instance
TM3_DB_USER=tm3user
TM3_DB_PASS=model3pass
TM3_DB_NAME=teslamate_model3
TM3_ENCRYPTION_KEY=changeme_model3

# Model Y instance
TMY_DB_USER=tmyuser
TMY_DB_PASS=modelypass
TMY_DB_NAME=teslamate_modely
TMY_ENCRYPTION_KEY=changeme_modely

# Grafana
GF_SECURITY_ADMIN_PASSWORD=yourpasswordhere

# Authelia (SSO & 2FA)
# Generate secrets with: openssl rand -hex 32
AUTHELIA_SESSION_SECRET=changeme_session_secret_64chars
AUTHELIA_STORAGE_ENCRYPTION_KEY=changeme_storage_key_64chars

# Vaultwarden (Password Manager)
VAULTWARDEN_ADMIN_TOKEN=SuperLongRandomStringHereAtLeast64Chars!@#2026
# Example generation command on your host: openssl rand -base64 48

# Homepage Dashboard
HOMEPAGE_VAR_HOMEASSISTANT_KEY=changeme
HOMEPAGE_VAR_PORTAINER_KEY=changeme
HOMEPAGE_VAR_ADGUARD_USERNAME=changeme
HOMEPAGE_VAR_ADGUARD_PASSWORD=changeme

# Tailscale
TS_AUTHKEY=changeme

# PriceBuddy (Price Tracking)
PRICEBUDDY_DB_NAME=pricebuddy
PRICEBUDDY_DB_USER=pricebuddy
PRICEBUDDY_DB_PASS=changeme_pricebuddy
PRICEBUDDY_DB_ROOT_PASS=changeme_root
PRICEBUDDY_ADMIN_EMAIL=admin@example.com
PRICEBUDDY_ADMIN_PASS=changeme_admin
PRICEBUDDY_APP_KEY=changeme_app_key_base64

# Apprise API (Notification Gateway)
# No configuration required - uses defaults
# Access at: https://apprise.home.lan
# For PriceBuddy: Create a config key at https://apprise.home.lan and add your Telegram URL:
#   tgram://YOUR_BOT_TOKEN/6752202857

# Global
TZ=Europe/Lisbon
