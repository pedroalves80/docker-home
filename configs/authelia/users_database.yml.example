---
# Authelia users database
# Generate password hashes with: docker run --rm authelia/authelia:latest authelia crypto hash generate argon2
#
# Example:
#   docker run --rm -it authelia/authelia:latest authelia crypto hash generate argon2
#   Enter password, get hash, paste below
#
# Copy this file to users_database.yml and update with your values

users:
  yourusername:
    displayname: "Your Name"
    password: "$argon2id$v=19$m=65536,t=3,p=4$YOUR_HASH_HERE"
    email: your@email.com
    groups:
      - admins
